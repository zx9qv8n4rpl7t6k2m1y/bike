<script>
/* ── Config ─────────────────────────────────────────── */
var buildUrl    = "https://cdn.jsdelivr.net/gh/papamamia/bike@main/Build";  /* default — no CDN variable */
var DATA_FILE   = "496ef19dc1344bc2db194268e8f125bb.data.unityweb";
var WASM_FILE   = "4e089e97adce1fa7f0070920d0ed63ca.wasm.unityweb";
var DATA_PARTS  = 8;  /* 61.4MB / 8MB = 8 parts */

var container        = document.querySelector("#unity-container");
var canvas           = document.querySelector("#unity-canvas");
var loadingCover     = document.querySelector("#loading-cover");
var progressBarFull  = document.querySelector("#unity-progress-bar-full");
var dlStatus         = document.querySelector("#dl-status");

if (/iPhone|iPad|iPod|Android/i.test(navigator.userAgent)) {
  container.className = "unity-mobile";
}

canvas.style.background  = "url('https://cdn.jsdelivr.net/gh/papamamia/bike@main/background.png') center / cover";
loadingCover.style.display = "";

/* DATA 0-55%, WASM 55-70%, Unity 70-100% */
function setBar(pct, label) {
  progressBarFull.style.width = pct.toFixed(1) + '%';
  if (dlStatus) dlStatus.textContent = label || '';
}

/* ── Download & decode helpers ───────────────────────── */
async function fetchDataParts() {
  var parts = [];
  for (var i = 0; i < DATA_PARTS; i++) {
    setBar((i/DATA_PARTS)*55, 'Downloading data... ' + (i+1) + '/' + DATA_PARTS);
    var r = await fetch(buildUrl + '/' + DATA_FILE + '.part' + i);
    if (!r.ok) throw new Error('data part' + i + ' HTTP ' + r.status);
    parts.push(new Uint8Array(await r.arrayBuffer()));
    setBar(((i+1)/DATA_PARTS)*55, 'Downloading data... ' + (i+1) + '/' + DATA_PARTS);
    console.log('[Data] part' + i + ': ' + parts[parts.length-1].length + ' bytes');
  }
  var total = parts.reduce(function(s,p){return s+p.length;},0);
  var merged = new Uint8Array(total); var off = 0;
  for (var j=0;j<parts.length;j++){merged.set(parts[j],off);off+=parts[j].length;}
  console.log('[Data] merged: ' + total + ' bytes');
  return merged;
}

/* Brotli-decode .unityweb → raw bytes → blob URL (no .unityweb in fragment) */
function unitywebBlobUrl(uint8, filename) {
  var data = uint8;
  if (typeof BrotliDecode === 'function') {
    try {
      data = BrotliDecode(uint8);
      console.log('[Brotli] ' + filename + ' decoded: ' + data.length + ' bytes');
      filename = filename.replace('.unityweb', '');
    } catch(e) { console.warn('[Brotli] decode failed for ' + filename + ':', e.message); }
  }
  var blob = new Blob([data], {type:'application/octet-stream'});
  return URL.createObjectURL(blob) + '#' + encodeURIComponent(filename);
}

/* ── State ───────────────────────────────────────────── */
var player         = null;
var leaderboard    = null;
var myGameInstance = null;
var payments       = null;
var promptCanShow  = false;
var reviewCanShow  = false;
var unityStarted   = false;

canvas.addEventListener('touchstart', function(){ window.focus(); });
canvas.addEventListener('pointerdown', function(){ window.focus(); });

/* ── YaGames init ────────────────────────────────────── */
YaGames.init().then(function(ysdk) {
  window.ysdk = ysdk;
  InitPayments();
  try { ysdk.shortcut.canShowPrompt().then(function(p){ if(p.canShow) promptCanShow=true; }); } catch(e){}
  try {
    ysdk.feedback.canReview().then(function(d){ if(d.value) reviewCanShow=true; });
    ysdk.shortcut.canShowPrompt().then(function(p){ if(p.canShow) promptCanShow=true; });
  } catch(e){}
});

/* ── Loader + part download ──────────────────────────── */
var script = document.createElement("script");
script.src = buildUrl + "/Builds.loader.js";
script.onload = async function() {
  try {
    /* 1. Data: 8 parts → merge → BrotliDecode */
    var dataBytes = await fetchDataParts();
    var dataUrl   = unitywebBlobUrl(dataBytes, DATA_FILE);

    /* 2. WASM: direct fetch → BrotliDecode */
    setBar(55, 'Downloading WASM...');
    var wasmResp  = await fetch(buildUrl + '/' + WASM_FILE);
    if (!wasmResp.ok) throw new Error('WASM HTTP ' + wasmResp.status);
    var wasmUrl   = unitywebBlobUrl(new Uint8Array(await wasmResp.arrayBuffer()), WASM_FILE);
    setBar(70, 'Starting game...');
  } catch(e) { alert('Download error: ' + e.message); return; }

  if (!unityStarted) {
    unityStarted = true;
    createUnityInstance(canvas, {
      dataUrl:            dataUrl,
      frameworkUrl:       buildUrl + "/1b96707ce967fbc731d3137d8bd7ca6f.js.unityweb",
      codeUrl:            wasmUrl,
      streamingAssetsUrl: "StreamingAssets",
      companyName:        "DefaultCompany",
      productName:        "SuperBike",
      productVersion:     "0.1"
    }, function(progress) {
      setBar(70 + progress * 30, progress < 1 ? 'Loading... ' + Math.round(70 + progress*30) + '%' : '');
    }).then(function(inst) {
      myGameInstance = inst;
      loadingCover.style.display = "none";
    }).catch(function(msg) { alert(msg); });
  }
};
document.body.appendChild(script);

/* ── Game functions (original, all English) ─────────── */
function PaintRBT(rbt) {
  try { document.getElementById(rbt).style.background = '#ff0000'; } catch(e) { console.error(e); }
}
function StaticRBTDeactivate() {}

function InitPlayer(photoSize, _scopes) {
  try {
    return window.ysdk.getPlayer({scopes:_scopes}).then(function(_p) {
      player = _p;
      var playerName = player.getName();
      var playerPhoto = player.getPhoto(photoSize);
      if (!_scopes) { playerName = "anonymous"; playerPhoto = "null"; }
      if (player.getMode() === 'lite') {
        console.log('Not Authorized'); NotAuthorized();
      } else {
        console.log('Authorized Ok');
        myGameInstance.SendMessage('YandexGame','SetAuthorization',JSON.stringify({
          playerAuth:"resolved", playerName:playerName,
          playerId:player.getUniqueID(), playerPhoto:playerPhoto
        }));
        window.focus();
      }
    }).catch(function(e){ console.log('Authorized err',e.message); NotAuthorized(); });
  } catch(e) { console.error('CRASH init Player:',e.message); window.focus(); }
}
function NotAuthorized() {
  try {
    myGameInstance.SendMessage('YandexGame','SetAuthorization',JSON.stringify({
      playerAuth:"rejected", playerName:"unauthorized",
      playerId: player ? player.getUniqueID() : "0",
      playerPhoto:"null"
    }));
  } catch(e) { console.error('CRASH Not Authorized:',e.message); }
}
function AuthorizationCheck(photoSize, scopes) { InitPlayer(photoSize, scopes); }
function OpenAuthDialog(photoSize, scopes) {
  try {
    window.ysdk.auth.openAuthDialog().then(function(){
      InitPlayer(photoSize, scopes);
    }).catch(function(){ AuthorizationCheck(photoSize, scopes); });
  } catch(e) { console.log('CRASH Open Auth Dialog'); }
}

function InitPayments() {
  try {
    window.ysdk.getPayments().then(function(_p){
      console.log('Purchases available'); payments=_p;
    }).catch(function(e){ console.log('Purchases not available',e.message); });
  } catch(e) { console.error('CRASH Init Payments:',e.message); }
}
function BuyPayments(id) {
  try {
    if(payments) {
      payments.purchase(id).then(function(){
        console.log('Purchase Success');
        myGameInstance.SendMessage('YandexGame','OnPurchaseSuccess',id); window.focus();
      }).catch(function(e){
        console.error('Purchase Failed',e.message);
        myGameInstance.SendMessage('YandexGame','OnPurchaseFailed',id); window.focus();
      });
    } else console.log('Payments == null');
  } catch(e) { console.error('CRASH Buy Payments:',e.message); window.focus(); }
}
function GetPayments() {
  try {
    if(payments) {
      payments.getCatalog().then(function(products){
        var productID=[],title=[],description=[],imageURI=[],priceValue=[],purchased=[];
        for(var i=0;i<products.length;i++){
          productID[i]=products[i].id; title[i]=products[i].title;
          description[i]=products[i].description; imageURI[i]=products[i].imageURI;
          priceValue[i]=products[i].priceValue; purchased[i]=0;
        }
        payments.getPurchases().then(function(purchases){
          for(var i1=0;i1<products.length;i1++)
            for(var i2=0;i2<purchases.length;i2++)
              if(products[i1].id===purchases[i2].productID) purchased[i1]++;
        }).then(function(){
          myGameInstance.SendMessage('YandexGame','PaymentsEntries',JSON.stringify({
            id:productID,title:title,description:description,
            imageURI:imageURI,priceValue:priceValue,purchased:purchased
          }));
        });
      });
    } else console.log('Get Payments: payments == null');
  } catch(e) { console.error('CRASH Get Payments:',e.message); }
}
function DeletePurchase(id) {
  try {
    if(payments) payments.getPurchases().then(function(ps){
      for(var i=0;i<ps.length;i++)
        if(ps[i].productID===id) payments.consumePurchase(ps[i].purchaseToken);
    }); else console.log('Delete Purchase: payments == null');
  } catch(e) { console.error('CRASH Delete Purchase:',e.message); }
}
function DeleteAllPurchases() {
  try {
    if(payments) payments.getPurchases().then(function(ps){
      for(var i=0;i<ps.length;i++) payments.consumePurchase(ps[i].purchaseToken);
    }); else console.log('Delete All Purchases: payments == null');
  } catch(e) { console.error('CRASH Delete All Purchases:',e.message); }
}

function SaveCloud(jsonData,flush) {
  try { player.setData({saves:[jsonData]},flush); } catch(e){ console.error('CRASH Save Cloud:',e.message); }
}
function LoadCloud() {
  try {
    player.getData(["saves"]).then(function(data){
      myGameInstance.SendMessage('YandexGame','SetLoadSaves',data.saves?JSON.stringify(data.saves):"noData");
    }).catch(function(){
      console.error('getData Error!');
      myGameInstance.SendMessage('YandexGame','SetLoadSaves',"noData");
    });
  } catch(e) {
    console.error('CRASH Load Saves Cloud:',e.message);
    setTimeout(function(){ LoadCloud(); }, 1000);
  }
}

function InitLeaderboard() {
  try {
    window.ysdk.getLeaderboards().then(function(_lb){
      leaderboard=_lb;
      myGameInstance.SendMessage('YandexGame','InitializedLB');
    });
  } catch(e) { console.error('CRASH Init Leaderboard:',e.message); setTimeout(InitLeaderboard,1000); }
}
function SetLeaderboardScores(name,score) {
  try {
    window.ysdk.getLeaderboards().then(function(lb){ lb.setLeaderboardScore(name,score); });
  } catch(e) { console.error('CRASH Set Leaderboard:',e.message); }
}
function GetLeaderboardScores(nameLB,maxPlayers,quantityTop,quantityAround,photoSize,auth) {
  try {
    window.ysdk.getLeaderboards().then(function(lb){
      var opts = auth ? {quantityTop:quantityTop,includeUser:true,quantityAround:quantityAround}
                      : {quantityTop:quantityTop};
      lb.getLeaderboardEntries(''+nameLB,opts).then(function(res){
        EntriesLB(res,nameLB,maxPlayers,photoSize);
      });
    });
  } catch(e) { console.error('CRASH Get Leaderboard:',e.message); }
}
function EntriesLB(res,nameLB,maxPlayers,photoSize) {
  var n=Math.min(res.entries.length,maxPlayers),txt='';
  var rank=[],photo=[],playersName=[],scorePlayers=[];
  for(var i=0;i<n;i++){
    rank[i]=res.entries[i].rank; scorePlayers[i]=res.entries[i].score;
    photo[i]=(photoSize==='nonePhoto'||res.entries[i].player.scopePermissions.avatar!=="allow")
      ?'nonePhoto':res.entries[i].player.getAvatarSrc(photoSize);
    playersName[i]=res.entries[i].player.scopePermissions.public_name==="allow"
      ?res.entries[i].player.publicName:"Anonymous";
    txt+=rank[i]+'. '+playersName[i]+': '+scorePlayers[i]+'\n';
  }
  myGameInstance.SendMessage('YandexGame','LeaderboardEntries',JSON.stringify({
    nameLB:nameLB,entries:n===0?'No data':txt,
    rank:rank,photo:photo,playersName:playersName,scorePlayers:scorePlayers
  }));
}

function FullscreenShow() {
  try {
    window.ysdk.adv.showFullscreenAdv({callbacks:{
      onOpen:  function(){ myGameInstance.SendMessage('YandexGame','OpenFullscreen'); },
      onClose: function(){ myGameInstance.SendMessage('YandexGame','CloseFullscreen'); window.focus(); }
    }});
  } catch(e) { console.error('CRASH Fullscreen:',e.message); }
}
function RewardedShow(id) {
  try {
    window.ysdk.adv.showRewardedVideo({callbacks:{
      onOpen:     function(){ myGameInstance.SendMessage('YandexGame','OpenVideo'); },
      onClose:    function(){ myGameInstance.SendMessage('YandexGame','CloseVideo'); window.focus(); },
      onRewarded: function(){ myGameInstance.SendMessage('YandexGame','RewardVideo',id); },
      onError:    function(err){ myGameInstance.SendMessage('YandexGame','ErrorVideo'); console.log(err); }
    }});
  } catch(e) { console.error('CRASH Rewarded:',e.message); }
}
function LanguageRequest() {
  try { myGameInstance.SendMessage('YandexGame','SetLanguage',window.ysdk.environment.i18n.lang); }
  catch(e){ console.error('CRASH Language:',e.message); }
}
function RequestingEnvironmentData() {
  try {
    myGameInstance.SendMessage('YandexGame','SetEnvironmentData',JSON.stringify({
      language:window.ysdk.environment.i18n.lang, domain:window.ysdk.environment.i18n.tld,
      deviceType:window.ysdk.deviceInfo.type, isMobile:window.ysdk.deviceInfo.isMobile(),
      isDesktop:window.ysdk.deviceInfo.isDesktop(), isTablet:window.ysdk.deviceInfo.isTablet(),
      isTV:window.ysdk.deviceInfo.isTV(), appID:window.ysdk.environment.app.id,
      browserLang:window.ysdk.environment.browser.lang, payload:window.ysdk.environment.payload,
      promptCanShow:promptCanShow, reviewCanShow:reviewCanShow
    }));
  } catch(e){ console.error('CRASH Environment:',e.message); }
}
function Review() {
  try {
    window.ysdk.feedback.canReview().then(function(d){
      if(d.value){ window.ysdk.feedback.requestReview().then(function(r){
        myGameInstance.SendMessage('YandexGame','ReviewSent',r.feedbackSent?'true':'false'); window.focus();
      }); } else { console.log('reviewCanShow = false',d.reason); window.focus(); }
    });
  } catch(e){ console.error('CRASH Review:',e.message); window.focus(); }
}
function PromptShow() {
  try {
    window.ysdk.shortcut.showPrompt().then(function(r){
      myGameInstance.SendMessage('YandexGame',r.outcome==='accepted'?'OnPromptSuccess':'OnPromptFail');
      window.focus();
    });
  } catch(e){ console.error('CRASH Prompt:',e.message); window.focus(); }
}
function StickyAdActivity(show) {
  try {
    window.ysdk.adv.getBannerAdvStatus().then(function(d){
      if(d.stickyAdvIsShowing){ if(!show) window.ysdk.adv.hideBannerAdv(); }
      else if(d.reason) console.log('Sticky not shown:',d.reason);
      else if(show) window.ysdk.adv.showBannerAdv();
    });
  } catch(e){ console.error('CRASH Sticky:',e.message); }
}
</script>
<!-- Sticky Bottom Center Ad (728x90) with Smooth Slide-Out and Reappearance -->
<style>
  /* Container: Bottom center, fixed, with overflow hidden */
  #ad-container {
    position: fixed;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: min(728px, calc(100% - 20px)); /* 728px, 10px margin on mobile */
    height: 90px;
    background: rgba(0, 0, 0, 0.90);
    display: none;
    z-index: 99999;
    border-radius: 0; /* Sharp corners */
    overflow: hidden;
    box-shadow: 0 -2px 12px rgba(0, 0, 0, 0.45);
    box-sizing: border-box;
    transition: transform 0.5s ease-in-out; /* Smooth slide-in/out animation */
  }

  /* Slide-out animation */
  #ad-container.hidden {
    transform: translate(-50%, 100%); /* Slide down out of view */
  }

  #ad-iframe {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 745px; /* Updated width */
    height: 90px; /* Updated height */
    border: 0;
    display: block;
    overflow: hidden;
    pointer-events: auto;
    box-sizing: content-box;
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  
  #ad-iframe::-webkit-scrollbar {
    display: none;
    width: 0;
    height: 0;
  }

  /* Close button with arrow */
  #close-ad {
    position: absolute;
    top: 6px;
    right: 8px;
    background: #ff4d4d;
    color: #fff;
    border: none;
    padding: 5px 9px;
    font-size: 13px;
    border-radius: 4px;
    cursor: not-allowed;
    opacity: 0.72;
    z-index: 100000;
    display: flex;
    align-items: center;
  }
  #close-ad.enabled {
    cursor: pointer;
    opacity: 1;
  }
  #close-ad::before {
    content: '↓'; /* Down arrow for bottom ad */
    margin-right: 4px;
  }

  /* Right mask for scrollbar */
  #ad-right-mask {
    position: absolute;
    top: 0;
    right: 0;
    width: 12px;
    height: 100%;
    pointer-events: none;
    background: linear-gradient(to right, rgba(0, 0, 0, 0), rgba(0, 0, 0, 0.9));
    z-index: 99999;
  }

  /* Mobile adjustments */
  @media (max-width: 440px) {
    #ad-container {
      width: calc(100% - 12px);
      left: 50%;
      transform: translateX(-50%);
      border-radius: 0; /* Sharp corners on mobile */
    }
    #ad-iframe {
      width: 728px;
    }
  }
</style>

